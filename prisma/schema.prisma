generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique
  passwordHash String      @map("password_hash")
  fullName     String?     @map("full_name")
  tokenVersion Int         @default(0) @map("token_version")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  roles        UserRole[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  resource    String
  action      String
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    Int      @map("role_id")
  grantedBy String?  @map("granted_by") @db.Uuid
  grantedAt DateTime @default(now()) @map("granted_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  jti       String   @db.Uuid
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AccessAudit {
  id        BigInt   @id @default(autoincrement())
  actorId   String?  @map("actor_id") @db.Uuid
  targetId  String?  @map("target_id") @db.Uuid
  action    String
  metadata  Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("access_audit")
}

model Customer {
  id      String  @id @default(uuid()) @db.Uuid
  code    String?
  name    String
  fbZalo  String? @map("fb_zalo")
  phone   String?
  address String?
  note    String?
  sheetId String? @map("sheet_id")
  shipRatePerKg Decimal? @map("ship_rate_per_kg") @db.Decimal(14, 2)
  createdAt DateTime @default(now()) @map("created_at")
  orders  Order[]

  @@map("customers")
}

enum OrderStatus {
  draft
  quoted
  deposited
  purchasing
  purchased
  jp_warehouse
  customs
  tax_done
  vn_warehouse
  delivered
  completed
  closed
  cancelled
}

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  code        String      @unique
  customerId  String      @map("customer_id") @db.Uuid
  status      OrderStatus @default(draft)
  saleId      String?     @map("sale_id") @db.Uuid
  totalQuote  Decimal?    @map("total_quote") @db.Decimal(14, 2)
  exchangeRate     Decimal? @map("exchange_rate") @db.Decimal(12, 4)
  shipAmount       Decimal  @default(0) @map("ship_amount") @db.Decimal(14, 2)
  shipCurrency     String   @default("JPY") @map("ship_currency")
  surchargeAmount  Decimal  @default(0) @map("surcharge_amount") @db.Decimal(14, 2)
  surchargeCurrency String  @default("VND") @map("surcharge_currency")
  discountAmount   Decimal  @default(0) @map("discount_amount") @db.Decimal(14, 2)
  discountCurrency String   @default("VND") @map("discount_currency")
  serviceFeeAmount      Decimal @default(0) @map("service_fee_amount") @db.Decimal(14, 2)
  serviceFeeCurrency    String  @default("VND") @map("service_fee_currency")
  jpDomesticShipAmount  Decimal @default(0) @map("jp_domestic_ship_amount") @db.Decimal(14, 2)
  jpDomesticShipCurrency String @default("JPY") @map("jp_domestic_ship_currency")
  intlShipAmount        Decimal @default(0) @map("intl_ship_amount") @db.Decimal(14, 2)
  intlShipCurrency      String  @default("VND") @map("intl_ship_currency")
  totalVnd         Decimal? @map("total_vnd") @db.Decimal(16, 2)
  deposit     Decimal     @default(0) @db.Decimal(14, 2)
  paidAt      DateTime?   @map("paid_at")
  needsCheck  Boolean     @default(false) @map("needs_check")
  checkNote   String?     @map("check_note")
  publicToken String      @unique @map("public_token")
  orderDate   DateTime    @default(now()) @map("order_date")
  createdAt   DateTime    @default(now()) @map("created_at")
  customer    Customer    @relation(fields: [customerId], references: [id])
  items       OrderItem[]
  trackings   Tracking[]
  payments    Payment[]
  logs        OrderLog[]

  @@index([status])
  @@map("orders")
}

model OrderLog {
  id        BigInt   @id @default(autoincrement())
  orderId   String   @map("order_id") @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  actorName String?  @map("actor_name")
  action    String
  changes   Json?
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_logs")
}

model OrderItem {
  id           String  @id @default(uuid()) @db.Uuid
  orderId      String  @map("order_id") @db.Uuid
  name         String
  url          String?
  qty          Int     @default(1)
  unitPriceJpy Decimal @map("unit_price_jpy") @db.Decimal(12, 2)
  shipJpy      Decimal? @map("ship_jpy") @db.Decimal(12, 2)
  purchaseDate DateTime? @map("purchase_date")
  paymentMethod String? @map("payment_method")
  note         String?
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Tracking {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String?  @map("order_id") @db.Uuid
  code       String
  jpName     String?  @map("jp_name")
  jpPriceJpy Decimal? @map("jp_price_jpy") @db.Decimal(12, 2)
  jpWeightKg Decimal? @map("jp_weight_kg") @db.Decimal(8, 3)
  vnWeightKg Decimal? @map("vn_weight_kg") @db.Decimal(8, 3)
  unitPriceVndPerKg Decimal? @map("unit_price_vnd_per_kg") @db.Decimal(14, 2)
  shipRateCurrency String @default("VND") @map("ship_rate_currency")
  vnTrackingCode String? @map("vn_tracking_code")
  cartonId   String?  @map("carton_id") @db.Uuid
  review     String?
  url        String?
  packedAt   DateTime? @map("packed_at")
  docCapturedAt DateTime? @map("doc_captured_at")
  shipmentId String?  @map("shipment_id") @db.Uuid
  status     String   @default("new")
  createdAt  DateTime @default(now()) @map("created_at")
  order      Order?   @relation(fields: [orderId], references: [id])
  shipment   Shipment? @relation(fields: [shipmentId], references: [id])
  carton     Carton?  @relation(fields: [cartonId], references: [id])
  logs       TrackingLog[]

  @@index([code])
  @@map("trackings")
}

// Kiện / carton: kho Nhật báo cân tổng; hệ thống cộng cân lẻ tracking để đối soát
model Carton {
  id              String     @id @default(uuid()) @db.Uuid
  code            String
  declaredWeightKg Decimal?  @map("declared_weight_kg") @db.Decimal(8, 3)
  packedDate      DateTime?  @map("packed_date")
  note            String?
  createdAt       DateTime   @default(now()) @map("created_at")
  trackings       Tracking[]

  @@map("cartons")
}

model TrackingLog {
  id         BigInt   @id @default(autoincrement())
  trackingId String   @map("tracking_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")
  tracking   Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  @@map("tracking_logs")
}

model Shipment {
  id         String     @id @default(uuid()) @db.Uuid
  code       String     @unique
  departedAt DateTime?  @map("departed_at")
  arrivedAt  DateTime?  @map("arrived_at")
  status     String     @default("open")
  trackings  Tracking[]
  documents  Document[]

  @@map("shipments")
}

model Document {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String?  @map("order_id") @db.Uuid
  shipmentId String?  @map("shipment_id") @db.Uuid
  type       String
  objectKey  String   @map("object_key")
  uploadedBy String?  @map("uploaded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  shipment   Shipment? @relation(fields: [shipmentId], references: [id])

  @@map("documents")
}

model Payment {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  type       String
  amountVnd  Decimal  @map("amount_vnd") @db.Decimal(14, 2)
  currency     String  @default("VND")
  amountOrig   Decimal @default(0) @map("amount_orig") @db.Decimal(14, 2)
  exchangeRate Decimal? @map("exchange_rate") @db.Decimal(12, 4)
  method     String?
  walletId   String?  @map("wallet_id") @db.Uuid
  recordedBy String?  @map("recorded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  order      Order    @relation(fields: [orderId], references: [id])
  wallet     Wallet?  @relation(fields: [walletId], references: [id])

  @@map("payments")
}

model Debt {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  orderId    String?  @map("order_id") @db.Uuid
  balance    Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([orderId])
  @@map("debts")
}

model Wallet {
  id       String        @id @default(uuid()) @db.Uuid
  name     String        @unique
  currency String        @default("VND")
  balance  Decimal       @default(0) @db.Decimal(16, 2)
  payments Payment[]
  txns     WalletTxn[]

  @@map("wallets")
}

// Quỹ tổng (vốn mua hàng, tính bằng JPY)
model Fund {
  id        String   @id @default("main")
  balance   Decimal  @default(0) @db.Decimal(16, 2)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fund")
}

model FundTxn {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   // topup | allocate
  amountYen Decimal  @map("amount_yen") @db.Decimal(16, 2)
  rate      Decimal? @db.Decimal(12, 4)
  walletId  String?  @map("wallet_id") @db.Uuid
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("fund_txns")
}

model WalletTxn {
  id           String   @id @default(uuid()) @db.Uuid
  walletId     String   @map("wallet_id") @db.Uuid
  amount       Decimal  @db.Decimal(16, 2)
  type         String
  category     String?
  note         String?
  transferRef  String?  @map("transfer_ref") @db.Uuid
  refOrderId   String?  @map("ref_order_id") @db.Uuid
  reconciled   Boolean  @default(false)
  statementRef String?  @map("statement_ref")
  createdAt    DateTime @default(now()) @map("created_at")
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_txns")
}

// Cọc cục theo khách (không gắn đơn) — khách nạp 15tr/25tr, clear theo tháng
model CustomerDeposit {
  id          String    @id @default(uuid()) @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  amountVnd   Decimal   @map("amount_vnd") @db.Decimal(14, 2)
  currency    String    @default("VND")
  amountOrig  Decimal   @default(0) @map("amount_orig") @db.Decimal(14, 2)
  exchangeRate Decimal? @map("exchange_rate") @db.Decimal(12, 4)
  payerName   String?   @map("payer_name")
  method      String?
  walletId    String?   @map("wallet_id") @db.Uuid
  note        String?
  paidAt      DateTime  @map("paid_at")
  confirmed   Boolean   @default(false)
  isOpening   Boolean   @default(false) @map("is_opening")
  confirmedBy String?   @map("confirmed_by") @db.Uuid
  confirmedAt DateTime? @map("confirmed_at")
  recordedBy  String?   @map("recorded_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([customerId])
  @@index([confirmed])
  @@map("customer_deposits")
}

model AppConfig {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

model BackupRun {
  id          String    @id @default(uuid()) @db.Uuid
  kind        String    @default("manual") // manual | scheduled
  status      String    @default("pending") // pending | running | success | failed
  scopeDb     Boolean   @default(true) @map("scope_db")
  scopeFiles  Boolean   @default(true) @map("scope_files")
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  sizeBytes   BigInt    @default(0) @map("size_bytes")
  remotePath  String?   @map("remote_path")
  error       String?
  logTail     String?   @map("log_tail")
  triggeredBy String?   @map("triggered_by") @db.Uuid

  @@index([startedAt])
  @@map("backup_runs")
}

// Chi phí phải trả kho/cty: chakubarai (착불) + gia cố + tiền cân tháng
model CompanyCost {
  id           String   @id @default(uuid()) @db.Uuid
  kind         String   // chakubarai | reinforce | weight | other
  month        String   // YYYY-MM
  amountVnd    Decimal  @map("amount_vnd") @db.Decimal(14, 2)
  currency     String   @default("VND")
  amountOrig   Decimal  @default(0) @map("amount_orig") @db.Decimal(14, 2)
  exchangeRate Decimal? @map("exchange_rate") @db.Decimal(12, 4)
  refId        String?  @map("ref_id") @db.Uuid
  note         String?
  paid         Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([month])
  @@map("company_costs")
}

// Chi phí phát sinh / đền bù khách (hàng vỡ...) - chỉ ghi nhận lỗ nội bộ, KHÔNG động công nợ khách
model Expense {
  id           String   @id @default(uuid()) @db.Uuid
  orderId      String?  @map("order_id") @db.Uuid
  kind         String   @default("compensation") // compensation | other
  amountVnd    Decimal  @map("amount_vnd") @db.Decimal(14, 2)
  currency     String   @default("VND")
  amountOrig   Decimal  @default(0) @map("amount_orig") @db.Decimal(14, 2)
  exchangeRate Decimal? @map("exchange_rate") @db.Decimal(12, 4)
  note         String?
  incurredAt   DateTime @map("incurred_at")
  recordedBy   String?  @map("recorded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("expenses")
}

// Lương nhân viên - chỉ super_admin xem
model Payroll {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String
  month     String   // YYYY-MM
  amountVnd Decimal  @map("amount_vnd") @db.Decimal(14, 2)
  note      String?
  paid      Boolean  @default(false)
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([month])
  @@map("payrolls")
}

model WeightRecon {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  jpWeight  Decimal? @map("jp_weight") @db.Decimal(8, 3)
  vnWeight  Decimal? @map("vn_weight") @db.Decimal(8, 3)
  diffKg    Decimal? @map("diff_kg") @db.Decimal(8, 3)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("weight_recon")
}
